# Mobilitybox API Key - get from https://themobilitybox.com
# WARNING: NEVER use a real key in tests. Tests always run in mock mode.
# WARNING: Live mode triggers REAL orders with REAL costs (49€/month).
# Request a sandbox/test key from support@themobilitybox.com before going live.
MOBILITYBOX_API_KEY=your_api_key_here

# Controls API behavior:
#   "mock"      - No real API calls. Realistic fake responses. DEFAULT & required for all tests.
#   "mock-fail" - Simulates a Mobilitybox API failure. For error path testing.
#   "live"      - Makes REAL API calls. Only set manually. Can trigger 49€/month subscriptions!
MOBILITYBOX_MODE=mock

# SQLite database file path (local development only)
# Note: On Vercel, the filesystem is ephemeral. Switch to Neon/Turso for production.
DATABASE_URL="file:./dev.db"
